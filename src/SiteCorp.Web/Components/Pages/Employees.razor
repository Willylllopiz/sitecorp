@page "/employees"
@page "/people"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@inject HumanResourcesApiClient HrClient

<PageTitle>SiteCorp | Candidatos</PageTitle>

@if (_isLoading)
{
    <section class="loading-panel">
        <div class="loader"></div>
        <p>Cargando candidatos y catalogos...</p>
    </section>
}
else
{
    <section class="page-header compact">
        <div>
            <p class="eyebrow">Capital humano</p>
            <h1>Candidatos</h1>
            <p class="subtitle">Registro inicial de candidatos antes de asociarlos a una entidad por contratacion.</p>
        </div>
        <div class="header-actions">
            <button class="action-button secondary" type="button" @onclick="LoadAsync">Actualizar</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="@_messageCss">@_message</div>
    }

    <section class="work-grid">
        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Nuevo candidato</p>
                    <h2>Datos base</h2>
                </div>
            </div>

            <form class="form-grid" @onsubmit="SavePersonAsync" @onsubmit:preventDefault>
                <label>
                    Nombres
                    <input @bind="_form.FirstName" required maxlength="120" />
                </label>
                <label>
                    Primer apellido
                    <input @bind="_form.FirstLastName" required maxlength="140" />
                </label>
                <label>
                    Segundo apellido
                    <input @bind="_form.SecondLastName" required maxlength="100" />
                </label>
                <label>
                    Carnet de Identidad
                    <input value="@_form.NationalId" @oninput="OnNationalIdInput" required maxlength="40" />
                </label>
                <label>
                    Fecha de nacimiento
                    <input type="date" @bind="_form.BirthDate" required />
                </label>
                <label>
                    Nivel educacional
                    <select value="@_form.EducationLevelId" @onchange="OnEducationLevelChanged" required>
                        @foreach (var item in _catalogs.EducationLevels)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>
                @if (RequiresSpecialty(_form.EducationLevelId))
                {
                    <label>
                        Especialidad
                        <input @bind="_form.Specialty" required maxlength="180" />
                    </label>
                }
                <label>
                    Estado civil
                    <select @bind="_form.MaritalStatusId" required>
                        @foreach (var item in _catalogs.MaritalStatuses)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>
                <label>
                    Genero
                    <select @bind="_form.GenderId" required>
                        @foreach (var item in _catalogs.Genders)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>
                <label>
                    Color de piel
                    <select @bind="_form.SkinColorId" required>
                        @foreach (var item in _catalogs.SkinColors)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>
                <label>
                    Afiliacion politica
                    <select @bind="_form.PoliticalAffiliationId" required>
                        @foreach (var item in _catalogs.PoliticalAffiliations)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>
                <label>
                    Tipo de empleo
                    <select @bind="_form.EmploymentTypeId" required>
                        @foreach (var item in _catalogs.EmploymentTypes)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" checked="@_form.HasDrivingLicense" @onchange="OnHasDrivingLicenseChanged" />
                    Licencia de conduccion
                </label>
                @if (_form.HasDrivingLicense)
                {
                    <div class="span-2 multi-select">
                        <button class="action-button secondary multi-select-trigger" type="button" @onclick="ToggleDrivingLicenseMenu">
                            @DrivingLicenseCategoriesLabel()
                        </button>
                        @if (_isDrivingLicenseMenuOpen)
                        {
                            <div class="multi-select-menu">
                                @foreach (var item in DrivingLicenseCategoryOptions)
                                {
                                    <label class="multi-select-option">
                                        <input type="checkbox"
                                               checked="@IsDrivingLicenseCategorySelected(item.Id)"
                                               @onchange="eventArgs => ToggleDrivingLicenseCategory(item.Id, eventArgs)" />
                                        <span>@CatalogOptionLabel(item)</span>
                                    </label>
                                }
                            </div>
                        }
                    </div>
                }
                <label>
                    Jubilado / recontratado
                    <select @bind="_form.RetireeRehireStatusId" required>
                        @foreach (var item in _catalogs.RetireeRehireStatuses)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>

                <label>
                    Direccion Particular
                    <input @bind="_form.PrivateAddress" required maxlength="220" />
                </label>
                <label>
                    Municipio
                    <input @bind="_form.City" required maxlength="120" />
                </label>
                <label>
                    Provincia
                    <input @bind="_form.Province" required maxlength="120" />
                </label>
                <label>
                    Codigo postal
                    <input @bind="_form.PostalCode" maxlength="40" />
                </label>
                <label>
                    Hijos
                    <input type="number" min="0" @bind="_form.NumberOfChildren" />
                </label>
                <label>
                    Estatura (cm)
                    <input type="number" min="0" step="0.01" @bind="_form.Height" />
                </label>
                <label>
                    Peso (Kg)
                    <input type="number" min="0" step="0.01" @bind="_form.Weight" />
                </label>
                <label>
                    Talla pantalon
                    <input @bind="_form.PantsSize" maxlength="30" />
                </label>
                <label>
                    Talla camisa
                    <input @bind="_form.ShirtSize" maxlength="30" />
                </label>
                <label>
                    Talla calzado
                    <input @bind="_form.ShoeSize" maxlength="30" />
                </label>
                <label>
                    Situacion defensa
                    <input @bind="_form.DefenseSituation" maxlength="180" />
                </label>
                <label>
                    Grado terminado
                    <input @bind="_form.CompletedDegree" maxlength="180" />
                </label>
                <label class="checkbox-label">
                    <input type="checkbox"
                           checked="@_form.PreEmploymentCheck"
                           @onchange="eventArgs => OnDocumentFlagChanged(eventArgs, CandidateDocumentKind.PreEmploymentCheck)" />
                    Chequeo pre-empleo
                </label>
                @if (_form.PreEmploymentCheck)
                {
                    <div class="span-2 document-upload">
                        <label>
                            Documento chequeo pre-empleo
                            <InputFile OnChange="eventArgs => OnDocumentSelectedAsync(eventArgs, CandidateDocumentKind.PreEmploymentCheck)" />
                        </label>
                        @if (_form.PreEmploymentCheckDocument is not null)
                        {
                            <span>@DocumentLabel(_form.PreEmploymentCheckDocument)</span>
                        }
                    </div>
                }
                <label class="checkbox-label">
                    <input type="checkbox"
                           checked="@_form.HasEmploymentContract"
                           @onchange="eventArgs => OnDocumentFlagChanged(eventArgs, CandidateDocumentKind.EmploymentContract)" />
                    Tiene contrato laboral
                </label>
                @if (_form.HasEmploymentContract)
                {
                    <div class="span-2 document-upload">
                        <label>
                            Documento contrato laboral
                            <InputFile OnChange="eventArgs => OnDocumentSelectedAsync(eventArgs, CandidateDocumentKind.EmploymentContract)" />
                        </label>
                        @if (_form.EmploymentContractDocument is not null)
                        {
                            <span>@DocumentLabel(_form.EmploymentContractDocument)</span>
                        }
                    </div>
                }
                <label class="checkbox-label">
                    <input type="checkbox"
                           checked="@_form.HasCriminalRecord"
                           @onchange="eventArgs => OnDocumentFlagChanged(eventArgs, CandidateDocumentKind.CriminalRecord)" />
                    Antecedentes penales
                </label>
                @if (_form.HasCriminalRecord)
                {
                    <div class="span-2 document-upload">
                        <label>
                            Documento antecedentes penales
                            <InputFile OnChange="eventArgs => OnDocumentSelectedAsync(eventArgs, CandidateDocumentKind.CriminalRecord)" />
                        </label>
                        @if (_form.CriminalRecordDocument is not null)
                        {
                            <span>@DocumentLabel(_form.CriminalRecordDocument)</span>
                        }
                    </div>
                }
                <label class="checkbox-label">
                    <input type="checkbox"
                           checked="@_form.HasDisciplinaryMeasures"
                           @onchange="eventArgs => OnDocumentFlagChanged(eventArgs, CandidateDocumentKind.DisciplinaryMeasures)" />
                    Medidas disciplinarias
                </label>
                @if (_form.HasDisciplinaryMeasures)
                {
                    <div class="span-2 document-upload">
                        <label>
                            Documento medidas disciplinarias
                            <InputFile OnChange="eventArgs => OnDocumentSelectedAsync(eventArgs, CandidateDocumentKind.DisciplinaryMeasures)" />
                        </label>
                        @if (_form.DisciplinaryMeasuresDocument is not null)
                        {
                            <span>@DocumentLabel(_form.DisciplinaryMeasuresDocument)</span>
                        }
                    </div>
                }

                <div class="form-actions span-2">
                    <button class="action-button" type="submit" disabled="@_isSaving">
                        @(_isSaving ? "Guardando..." : "Guardar candidato")
                    </button>
                </div>
            </form>
        </article>

        <article class="panel table-panel">
            <table>
                <thead>
                    <tr>
                        <th>Candidato</th>
                        <th>Identificador</th>
                        <th>Nacimiento</th>
                        <th>Direccion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var person in _people)
                    {
                        <tr>
                            <td><strong>@person.FullName</strong></td>
                            <td>@person.NationalId</td>
                            <td>@person.BirthDate.ToString("yyyy-MM-dd")</td>
                            <td>@person.Address</td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>
    </section>
}

@code {
    private const long MaxDocumentSizeBytes = 10 * 1024 * 1024;

    private readonly PersonForm _form = new();
    private HumanResourcesCatalogsResponse _catalogs = EmptyCatalogs();
    private IReadOnlyList<PersonResponse> _people = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _message;
    private string _messageCss = "alert-success";
    private bool _isDrivingLicenseMenuOpen;

    private IEnumerable<CatalogItemResponse> DrivingLicenseCategoryOptions =>
        _catalogs.DrivingLicenseCategories.Where(item => !IsNoDrivingLicenseCategory(item));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;

        try
        {
            _catalogs = await HrClient.GetCatalogsAsync();
            _people = await HrClient.GetPeopleAsync();
            ApplyCatalogDefaults();
        }
        catch (Exception exception)
        {
            ShowError(exception.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SavePersonAsync()
    {
        _isSaving = true;
        _message = null;

        try
        {
            if (_form.HasDrivingLicense && _form.DrivingLicenseCategoryIds.Count == 0)
            {
                ShowError("Selecciona al menos una categoria de licencia de conduccion.");
                return;
            }

            if (!EnsureSelectedDocuments())
            {
                return;
            }

            var request = new CreatePersonRequest(
                _form.FirstName,
                _form.FirstLastName,
                _form.SecondLastName,
                _form.NationalId,
                DateOnly.FromDateTime(_form.BirthDate),
                BuildAddress(),
                _form.NumberOfChildren,
                EmptyToNull(_form.DefenseSituation),
                _form.PreEmploymentCheck,
                _form.PreEmploymentCheck ? _form.PreEmploymentCheckDocument?.ToDto() : null,
                EmptyToNull(_form.CompletedDegree),
                _form.HasCriminalRecord,
                _form.HasCriminalRecord ? _form.CriminalRecordDocument?.ToDto() : null,
                _form.HasEmploymentContract,
                _form.HasEmploymentContract ? _form.EmploymentContractDocument?.ToDto() : null,
                _form.HasDisciplinaryMeasures,
                _form.HasDisciplinaryMeasures ? _form.DisciplinaryMeasuresDocument?.ToDto() : null,
                _form.EducationLevelId,
                RequiresSpecialty(_form.EducationLevelId) ? EmptyToNull(_form.Specialty) : null,
                _form.MaritalStatusId,
                _form.GenderId,
                _form.SkinColorId,
                _form.PoliticalAffiliationId,
                _form.EmploymentTypeId,
                _form.HasDrivingLicense,
                _form.HasDrivingLicense ? _form.DrivingLicenseCategoryIds : [],
                _form.RetireeRehireStatusId,
                new PhysicalDataDto(
                    _form.Height,
                    _form.Weight,
                    EmptyToNull(_form.PantsSize),
                    EmptyToNull(_form.ShirtSize),
                    EmptyToNull(_form.ShoeSize)));

            _ = await HrClient.CreatePersonAsync(request);
            _form.ResetAfterSave();
            ApplyCatalogDefaults();
            _people = await HrClient.GetPeopleAsync();
            ShowSuccess("Candidato registrado correctamente.");
        }
        catch (Exception exception)
        {
            ShowError(exception.Message);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private bool EnsureSelectedDocuments()
    {
        if (_form.PreEmploymentCheck && _form.PreEmploymentCheckDocument is null)
        {
            ShowError("Adjunta el documento del chequeo pre-empleo.");
            return false;
        }

        if (_form.HasEmploymentContract && _form.EmploymentContractDocument is null)
        {
            ShowError("Adjunta el documento del contrato laboral.");
            return false;
        }

        if (_form.HasCriminalRecord && _form.CriminalRecordDocument is null)
        {
            ShowError("Adjunta el documento de antecedentes penales.");
            return false;
        }

        if (_form.HasDisciplinaryMeasures && _form.DisciplinaryMeasuresDocument is null)
        {
            ShowError("Adjunta el documento de medidas disciplinarias.");
            return false;
        }

        return true;
    }

    private void ApplyCatalogDefaults()
    {
        _form.EducationLevelId = FirstId(_catalogs.EducationLevels, _form.EducationLevelId);
        _form.MaritalStatusId = FirstId(_catalogs.MaritalStatuses, _form.MaritalStatusId);
        _form.GenderId = FirstId(_catalogs.Genders, _form.GenderId);
        _form.SkinColorId = FirstId(_catalogs.SkinColors, _form.SkinColorId);
        _form.PoliticalAffiliationId = FirstId(_catalogs.PoliticalAffiliations, _form.PoliticalAffiliationId);
        _form.EmploymentTypeId = FirstId(_catalogs.EmploymentTypes, _form.EmploymentTypeId);
        _form.RetireeRehireStatusId = FirstId(_catalogs.RetireeRehireStatuses, _form.RetireeRehireStatusId);
        ClearSpecialtyWhenNotRequired();
    }

    private void OnHasDrivingLicenseChanged(ChangeEventArgs eventArgs)
    {
        _form.HasDrivingLicense = eventArgs.Value is true;

        if (!_form.HasDrivingLicense)
        {
            _form.DrivingLicenseCategoryIds.Clear();
            _isDrivingLicenseMenuOpen = false;
        }
    }

    private void OnDocumentFlagChanged(ChangeEventArgs eventArgs, CandidateDocumentKind documentKind)
    {
        var isChecked = eventArgs.Value is true;

        switch (documentKind)
        {
            case CandidateDocumentKind.PreEmploymentCheck:
                _form.PreEmploymentCheck = isChecked;
                break;
            case CandidateDocumentKind.EmploymentContract:
                _form.HasEmploymentContract = isChecked;
                break;
            case CandidateDocumentKind.CriminalRecord:
                _form.HasCriminalRecord = isChecked;
                break;
            case CandidateDocumentKind.DisciplinaryMeasures:
                _form.HasDisciplinaryMeasures = isChecked;
                break;
        }

        if (!isChecked)
        {
            ClearDocument(documentKind);
        }
    }

    private async Task OnDocumentSelectedAsync(InputFileChangeEventArgs eventArgs, CandidateDocumentKind documentKind)
    {
        var file = eventArgs.File;

        if (file.Size > MaxDocumentSizeBytes)
        {
            ClearDocument(documentKind);
            ShowError("El documento no puede superar 10 MB.");
            return;
        }

        try
        {
            using var readStream = file.OpenReadStream(MaxDocumentSizeBytes);
            using var memoryStream = new MemoryStream();
            await readStream.CopyToAsync(memoryStream);

            SetDocument(
                documentKind,
                new PersonDocumentForm(
                    file.Name,
                    string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType,
                    Convert.ToBase64String(memoryStream.ToArray()),
                    file.Size));
            _message = null;
        }
        catch (Exception exception)
        {
            ClearDocument(documentKind);
            ShowError($"No se pudo leer el documento: {exception.Message}");
        }
    }

    private void SetDocument(CandidateDocumentKind documentKind, PersonDocumentForm document)
    {
        switch (documentKind)
        {
            case CandidateDocumentKind.PreEmploymentCheck:
                _form.PreEmploymentCheckDocument = document;
                break;
            case CandidateDocumentKind.EmploymentContract:
                _form.EmploymentContractDocument = document;
                break;
            case CandidateDocumentKind.CriminalRecord:
                _form.CriminalRecordDocument = document;
                break;
            case CandidateDocumentKind.DisciplinaryMeasures:
                _form.DisciplinaryMeasuresDocument = document;
                break;
        }
    }

    private void ClearDocument(CandidateDocumentKind documentKind)
    {
        switch (documentKind)
        {
            case CandidateDocumentKind.PreEmploymentCheck:
                _form.PreEmploymentCheckDocument = null;
                break;
            case CandidateDocumentKind.EmploymentContract:
                _form.EmploymentContractDocument = null;
                break;
            case CandidateDocumentKind.CriminalRecord:
                _form.CriminalRecordDocument = null;
                break;
            case CandidateDocumentKind.DisciplinaryMeasures:
                _form.DisciplinaryMeasuresDocument = null;
                break;
        }
    }

    private static string DocumentLabel(PersonDocumentForm document)
    {
        return $"{document.FileName} ({FormatFileSize(document.Size)})";
    }

    private static string FormatFileSize(long size)
    {
        return size < 1024 * 1024
            ? $"{Math.Max(1L, size / 1024)} KB"
            : $"{size / 1024m / 1024m:0.##} MB";
    }

    private void ToggleDrivingLicenseMenu()
    {
        _isDrivingLicenseMenuOpen = !_isDrivingLicenseMenuOpen;
    }

    private bool IsDrivingLicenseCategorySelected(Guid categoryId)
    {
        return _form.DrivingLicenseCategoryIds.Contains(categoryId);
    }

    private void ToggleDrivingLicenseCategory(Guid categoryId, ChangeEventArgs eventArgs)
    {
        var isSelected = eventArgs.Value is true;

        if (isSelected && !_form.DrivingLicenseCategoryIds.Contains(categoryId))
        {
            _form.DrivingLicenseCategoryIds.Add(categoryId);
        }

        if (!isSelected)
        {
            _form.DrivingLicenseCategoryIds.Remove(categoryId);
        }
    }

    private string DrivingLicenseCategoriesLabel()
    {
        var selectedCodes = DrivingLicenseCategoryOptions
            .Where(item => _form.DrivingLicenseCategoryIds.Contains(item.Id))
            .Select(CatalogOptionLabel)
            .ToList();

        return selectedCodes.Count == 0
            ? "Selecciona categorias"
            : string.Join(", ", selectedCodes);
    }

    private void OnEducationLevelChanged(ChangeEventArgs eventArgs)
    {
        if (Guid.TryParse(eventArgs.Value?.ToString(), out var educationLevelId))
        {
            _form.EducationLevelId = educationLevelId;
        }

        ClearSpecialtyWhenNotRequired();
    }

    private void OnNationalIdInput(ChangeEventArgs eventArgs)
    {
        _form.NationalId = eventArgs.Value?.ToString() ?? string.Empty;

        if (TryGetBirthDateFromNationalId(_form.NationalId, out var birthDate))
        {
            _form.BirthDate = birthDate.ToDateTime(TimeOnly.MinValue);
        }
    }

    private AddressDto BuildAddress()
    {
        return new AddressDto(
            _form.PrivateAddress,
            null,
            _form.City,
            _form.Province,
            EmptyToNull(_form.PostalCode));
    }

    private void ShowSuccess(string message)
    {
        _message = message;
        _messageCss = "alert-success";
    }

    private void ShowError(string message)
    {
        _message = message;
        _messageCss = "alert-error";
    }

    private static Guid FirstId(IReadOnlyList<CatalogItemResponse> items, Guid current)
    {
        return current == Guid.Empty ? items.FirstOrDefault()?.Id ?? Guid.Empty : current;
    }

    private static string CatalogOptionLabel(CatalogItemResponse item)
    {
        return string.IsNullOrWhiteSpace(item.Code) ? item.Description : item.Code;
    }

    private static bool IsNoDrivingLicenseCategory(CatalogItemResponse item)
    {
        var normalized = NormalizeCatalogCode(item.Code);
        return normalized is "NINGUNA" or "NO" or "NO APLICA" or "NO_APLICA";
    }

    private bool RequiresSpecialty(Guid educationLevelId)
    {
        var code = _catalogs.EducationLevels.FirstOrDefault(item => item.Id == educationLevelId)?.Code;
        return RequiresSpecialtyCode(code);
    }

    private void ClearSpecialtyWhenNotRequired()
    {
        if (!RequiresSpecialty(_form.EducationLevelId))
        {
            _form.Specialty = null;
        }
    }

    private static bool RequiresSpecialtyCode(string? code)
    {
        var normalized = NormalizeCatalogCode(code);
        return normalized is "TECNICO MEDIO" or "SUPERIOR";
    }

    private static string NormalizeCatalogCode(string? code)
    {
        return (code ?? string.Empty)
            .Trim()
            .ToUpperInvariant()
            .Replace("É", "E")
            .Replace("  ", " ");
    }

    private static bool TryGetBirthDateFromNationalId(string nationalId, out DateOnly birthDate)
    {
        birthDate = default;

        var firstSixDigits = GetFirstDigits(nationalId, 6);
        if (firstSixDigits.Length < 6)
        {
            return false;
        }

        if (!int.TryParse(firstSixDigits[..2], out var yearDigits) ||
            !int.TryParse(firstSixDigits[2..4], out var month) ||
            !int.TryParse(firstSixDigits[4..6], out var day))
        {
            return false;
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var year = (today.Year / 100 * 100) + yearDigits;
        if (year > today.Year)
        {
            year -= 100;
        }

        try
        {
            birthDate = new DateOnly(year, month, day);
        }
        catch (ArgumentOutOfRangeException)
        {
            return false;
        }

        if (birthDate > today)
        {
            birthDate = birthDate.AddYears(-100);
        }

        return true;
    }

    private static string GetFirstDigits(string value, int maxDigits)
    {
        var digits = new char[maxDigits];
        var count = 0;

        foreach (var character in value)
        {
            if (!char.IsDigit(character))
            {
                continue;
            }

            digits[count] = character;
            count++;

            if (count == maxDigits)
            {
                break;
            }
        }

        return new string(digits, 0, count);
    }

    private static string? EmptyToNull(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static HumanResourcesCatalogsResponse EmptyCatalogs()
    {
        return new HumanResourcesCatalogsResponse([], [], [], [], [], [], [], []);
    }

    private enum CandidateDocumentKind
    {
        PreEmploymentCheck,
        EmploymentContract,
        CriminalRecord,
        DisciplinaryMeasures
    }

    private sealed record PersonDocumentForm(
        string FileName,
        string ContentType,
        string ContentBase64,
        long Size)
    {
        public DocumentAttachmentDto ToDto()
        {
            return new DocumentAttachmentDto(FileName, ContentType, ContentBase64);
        }
    }

    private sealed class PersonForm
    {
        public string FirstName { get; set; } = string.Empty;

        public string FirstLastName { get; set; } = string.Empty;

        public string SecondLastName { get; set; } = string.Empty;

        public string NationalId { get; set; } = string.Empty;

        public DateTime BirthDate { get; set; } = new(1990, 1, 1);

        public string PrivateAddress { get; set; } = string.Empty;

        public string City { get; set; } = string.Empty;

        public string Province { get; set; } = string.Empty;

        public string? PostalCode { get; set; }

        public int NumberOfChildren { get; set; }

        public string? DefenseSituation { get; set; }

        public bool PreEmploymentCheck { get; set; }

        public PersonDocumentForm? PreEmploymentCheckDocument { get; set; }

        public string? CompletedDegree { get; set; }

        public bool HasCriminalRecord { get; set; }

        public PersonDocumentForm? CriminalRecordDocument { get; set; }

        public bool HasEmploymentContract { get; set; }

        public PersonDocumentForm? EmploymentContractDocument { get; set; }

        public bool HasDisciplinaryMeasures { get; set; }

        public PersonDocumentForm? DisciplinaryMeasuresDocument { get; set; }

        public Guid EducationLevelId { get; set; }

        public string? Specialty { get; set; }

        public Guid MaritalStatusId { get; set; }

        public Guid GenderId { get; set; }

        public Guid SkinColorId { get; set; }

        public Guid PoliticalAffiliationId { get; set; }

        public Guid EmploymentTypeId { get; set; }

        public bool HasDrivingLicense { get; set; }

        public List<Guid> DrivingLicenseCategoryIds { get; } = new();

        public Guid RetireeRehireStatusId { get; set; }

