@page "/organization"
@rendermode InteractiveServer
@attribute [Authorize]
@inject HumanResourcesApiClient HrClient

<PageTitle>SiteCorp | Organizacion</PageTitle>

@if (_isLoading)
{
    <section class="loading-panel">
        <div class="loader"></div>
        <p>Cargando estructura organizativa...</p>
    </section>
}
else
{
    <section class="page-header compact">
        <div>
            <p class="eyebrow">Estructura</p>
            <h1>Organizacion</h1>
            <p class="subtitle">Alta inicial de grupos empresariales, empresas y UEB donde se contrataran candidatos.</p>
        </div>
        <div class="header-actions">
            <button class="action-button secondary" type="button" @onclick="LoadAsync">Actualizar</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="@_messageCss">@_message</div>
    }

    <section class="work-grid">
        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Nueva entidad</p>
                    <h2>Registro</h2>
                </div>
            </div>

            <form class="form-grid" @onsubmit="SaveEntityAsync" @onsubmit:preventDefault>
                <label>
                    Tipo
                    <select @bind="_form.Type">
                        <option value="@OrganizationEntityType.BusinessGroup">Grupo empresarial</option>
                        <option value="@OrganizationEntityType.Company">Empresa</option>
                        <option value="@OrganizationEntityType.BusinessUnit">UEB</option>
                    </select>
                </label>

                @if (_form.Type is OrganizationEntityType.Company)
                {
                    <label>
                        Grupo empresarial
                        <select @bind="_form.BusinessGroupId" required>
                            <option value="@Guid.Empty">Selecciona un grupo</option>
                            @foreach (var group in BusinessGroups)
                            {
                                <option value="@group.Id">@group.Name</option>
                            }
                        </select>
                    </label>
                }

                @if (_form.Type is OrganizationEntityType.BusinessUnit)
                {
                    <label>
                        Empresa
                        <select @bind="_form.CompanyId" required>
                            <option value="@Guid.Empty">Selecciona una empresa</option>
                            @foreach (var company in Companies)
                            {
                                <option value="@company.Id">@company.Name</option>
                            }
                        </select>
                    </label>
                }

                <label>
                    Nombre
                    <input @bind="_form.Name" required maxlength="180" />
                </label>

                <label class="span-2">
                    Descripcion
                    <textarea @bind="_form.Description" rows="3"></textarea>
                </label>

                @if (_form.Type is not OrganizationEntityType.BusinessGroup)
                {
                    <label>
                        Direccion
                        <input @bind="_form.AddressLine" required maxlength="220" />
                    </label>
                    <label>
                        Municipio
                        <input @bind="_form.Municipality" required maxlength="120" />
                    </label>
                    <label>
                        Provincia
                        <input @bind="_form.Province" required maxlength="120" />
                    </label>
                    <label>
                        Codigo postal
                        <input @bind="_form.PostalCode" maxlength="40" />
                    </label>
                }

                <div class="form-actions span-2">
                    <button class="action-button" type="submit" disabled="@_isSaving">
                        @(_isSaving ? "Guardando..." : "Guardar entidad")
                    </button>
                </div>
            </form>
        </article>

        <article class="panel table-panel">
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_entities.Any())
                    {
                        <tr>
                            <td colspan="3" class="empty-state">No hay entidades registradas.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var group in OrganizationTree)
                        {
                            <tr class="tree-row tree-level-0">
                                <td>
                                    <div class="tree-cell">
                                        <span class="tree-branch"></span>
                                        <span class="tree-node-icon">GE</span>
                                        <span>
                                            <strong>@group.Entity.Name</strong>
                                            <span>@(group.Entity.Description ?? "Sin descripcion")</span>
                                        </span>
                                    </div>
                                </td>
                                <td>@GetEntityTypeLabel(group.Entity.EntityType)</td>
                                <td><span class="@GetStatusCss(group.Entity)">@GetStatusLabel(group.Entity)</span></td>
                            </tr>

                            @foreach (var company in group.Companies)
                            {
                                <tr class="tree-row tree-level-1">
                                    <td>
                                        <div class="tree-cell">
                                            <span class="tree-branch"></span>
                                            <span class="tree-node-icon">E</span>
                                            <span>
                                                <strong>@company.Entity.Name</strong>
                                                <span>@(company.Entity.Description ?? "Sin descripcion")</span>
                                            </span>
                                        </div>
                                    </td>
                                    <td>@GetEntityTypeLabel(company.Entity.EntityType)</td>
                                    <td><span class="@GetStatusCss(company.Entity)">@GetStatusLabel(company.Entity)</span></td>
                                </tr>

                                @foreach (var unit in company.BusinessUnits)
                                {
                                    <tr class="tree-row tree-level-2">
                                        <td>
                                            <div class="tree-cell">
                                                <span class="tree-branch"></span>
                                                <span class="tree-node-icon">UEB</span>
                                                <span>
                                                    <strong>@unit.Name</strong>
                                                    <span>@(unit.Description ?? "Sin descripcion")</span>
                                                </span>
                                            </div>
                                        </td>
                                        <td>@GetEntityTypeLabel(unit.EntityType)</td>
                                        <td><span class="@GetStatusCss(unit)">@GetStatusLabel(unit)</span></td>
                                    </tr>
                                }
                            }
                        }

                        @foreach (var entity in OrphanEntities)
                        {
                            <tr class="tree-row tree-level-0">
                                <td>
                                    <div class="tree-cell">
                                        <span class="tree-branch"></span>
                                        <span class="tree-node-icon">?</span>
                                        <span>
                                            <strong>@entity.Name</strong>
                                            <span>@(entity.Description ?? "Sin descripcion")</span>
                                        </span>
                                    </div>
                                </td>
                                <td>@GetEntityTypeLabel(entity.EntityType)</td>
                                <td><span class="@GetStatusCss(entity)">@GetStatusLabel(entity)</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </article>
    </section>
}

@code {
    private readonly OrganizationForm _form = new();
    private IReadOnlyList<OrganizationEntityResponse> _entities = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _message;
    private string _messageCss = "alert-success";

    private IEnumerable<OrganizationEntityResponse> BusinessGroups =>
        _entities
            .Where(entity => entity.EntityType is OrganizationEntityType.BusinessGroup)
            .OrderBy(entity => entity.Name);

    private IEnumerable<OrganizationEntityResponse> Companies =>
        _entities
            .Where(entity => entity.EntityType is OrganizationEntityType.Company)
            .OrderBy(entity => entity.Name);

    private IEnumerable<BusinessGroupNode> OrganizationTree => BuildOrganizationTree();

    private IEnumerable<OrganizationEntityResponse> OrphanEntities => _entities
        .Where(IsOrphanEntity)
        .OrderBy(entity => entity.Name);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;

        try
        {
            _entities = await HrClient.GetOrganizationEntitiesAsync();
        }
        catch (Exception exception)
        {
            ShowError(exception.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveEntityAsync()
    {
        _isSaving = true;
        _message = null;

        try
        {
            _ = _form.Type switch
            {
                OrganizationEntityType.BusinessGroup => await HrClient.CreateBusinessGroupAsync(
                    new CreateBusinessGroupRequest(_form.Name, EmptyToNull(_form.Description))),
                OrganizationEntityType.Company => await HrClient.CreateCompanyAsync(
                    new CreateCompanyRequest(_form.BusinessGroupId, _form.Name, EmptyToNull(_form.Description), BuildAddress())),
                OrganizationEntityType.BusinessUnit => await HrClient.CreateBusinessUnitAsync(
                    new CreateBusinessUnitRequest(_form.CompanyId, _form.Name, EmptyToNull(_form.Description), BuildAddress())),
                _ => throw new InvalidOperationException("Tipo de entidad no soportado.")
            };

            _form.ResetAfterSave();
            ShowSuccess("Entidad registrada correctamente.");
            _entities = await HrClient.GetOrganizationEntitiesAsync();
        }
        catch (Exception exception)
        {
            ShowError(exception.Message);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private AddressDto BuildAddress()
    {
        return new AddressDto(
            _form.AddressLine,
            null,
            _form.Municipality,
            _form.Province,
            EmptyToNull(_form.PostalCode));
    }

    private void ShowSuccess(string message)
    {
        _message = message;
        _messageCss = "alert-success";
    }

    private void ShowError(string message)
    {
        _message = message;
        _messageCss = "alert-error";
    }

    private static string GetEntityTypeLabel(OrganizationEntityType entityType) => entityType switch
    {
        OrganizationEntityType.BusinessGroup => "Grupo empresarial",
        OrganizationEntityType.Company => "Empresa",
        OrganizationEntityType.BusinessUnit => "UEB",
        _ => entityType.ToString()
    };

    private static string GetStatusCss(OrganizationEntityResponse entity) =>
        entity.IsActive ? "pill success" : "pill muted";

    private static string GetStatusLabel(OrganizationEntityResponse entity) =>
        entity.IsActive ? "Activa" : "Inactiva";

    private IReadOnlyList<BusinessGroupNode> BuildOrganizationTree()
    {
        IReadOnlyList<OrganizationEntityResponse> noUnits = Array.Empty<OrganizationEntityResponse>();
        IReadOnlyList<CompanyNode> noCompanies = Array.Empty<CompanyNode>();

        var unitsByCompany = _entities
            .Where(entity => entity.EntityType is OrganizationEntityType.BusinessUnit && entity.CompanyId.HasValue)
            .GroupBy(entity => entity.CompanyId!.Value)
            .ToDictionary(
                group => group.Key,
                group => group.OrderBy(entity => entity.Name).ToList());

        var companiesByGroup = _entities
            .Where(entity => entity.EntityType is OrganizationEntityType.Company && entity.BusinessGroupId.HasValue)
            .GroupBy(entity => entity.BusinessGroupId!.Value)
            .ToDictionary(
                group => group.Key,
                group => group
                    .OrderBy(entity => entity.Name)
                    .Select(company => new CompanyNode(
                        company,
                        unitsByCompany.TryGetValue(company.Id, out var units) ? units : noUnits))
                    .ToList());

        return _entities
            .Where(entity => entity.EntityType is OrganizationEntityType.BusinessGroup)
            .OrderBy(entity => entity.Name)
            .Select(group => new BusinessGroupNode(
                group,
                companiesByGroup.TryGetValue(group.Id, out var companies) ? companies : noCompanies))
            .ToList();
    }

    private bool IsOrphanEntity(OrganizationEntityResponse entity)
    {
        return entity.EntityType switch
        {
            OrganizationEntityType.Company => !entity.BusinessGroupId.HasValue ||
                !_entities.Any(group => group.Id == entity.BusinessGroupId.Value),
            OrganizationEntityType.BusinessUnit => !entity.CompanyId.HasValue ||
                !_entities.Any(company => company.Id == entity.CompanyId.Value),
            _ => false
        };
    }

    private static string? EmptyToNull(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private sealed record BusinessGroupNode(
        OrganizationEntityResponse Entity,
        IReadOnlyList<CompanyNode> Companies);

    private sealed record CompanyNode(
        OrganizationEntityResponse Entity,
        IReadOnlyList<OrganizationEntityResponse> BusinessUnits);

    private sealed class OrganizationForm
    {
        public OrganizationEntityType Type { get; set; } = OrganizationEntityType.BusinessGroup;

        public Guid BusinessGroupId { get; set; }

        public Guid CompanyId { get; set; }

        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        public string AddressLine { get; set; } = string.Empty;

        public string Municipality { get; set; } = string.Empty;

        public string Province { get; set; } = string.Empty;

        public string? PostalCode { get; set; }

        public void ResetAfterSave()
        {
            Name = string.Empty;
            Description = null;
            AddressLine = string.Empty;
            Municipality = string.Empty;
            Province = string.Empty;
            PostalCode = null;
        }
    }
}
