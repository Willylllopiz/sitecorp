@page "/positions"
@page "/hiring"
@rendermode InteractiveServer
@attribute [Authorize]
@inject HumanResourcesApiClient HrClient

<PageTitle>SiteCorp | Contratacion</PageTitle>

@if (_isLoading)
{
    <section class="loading-panel">
        <div class="loader"></div>
        <p>Cargando contratacion...</p>
    </section>
}
else
{
    <section class="page-header compact">
        <div>
            <p class="eyebrow">Plantilla aprobada</p>
            <h1>Contratacion</h1>
            <p class="subtitle">Crea cargos, define plazas por entidad y registra nuevas relaciones laborales.</p>
        </div>
        <div class="header-actions">
            <button class="action-button secondary" type="button" @onclick="LoadAsync">Actualizar</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="@_messageCss">@_message</div>
    }

    <section class="work-grid hiring-setup">
        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Orden global</p>
                    <h2>Area</h2>
                </div>
            </div>

            <form class="form-grid single" @onsubmit="SaveAreaAsync" @onsubmit:preventDefault>
                <label>
                    Nombre
                    <input @bind="_areaForm.Name" required maxlength="140" />
                </label>
                <label>
                    Prioridad
                    <input type="number" min="0" @bind="_areaForm.Priority" />
                </label>
                <div class="form-actions">
                    <button class="action-button" type="submit" disabled="@_isSaving">
                        Guardar area
                    </button>
                </div>
            </form>
        </article>

        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Catalogo interno</p>
                    <h2>Cargo</h2>
                </div>
            </div>

            <form class="form-grid single" @onsubmit="SavePositionAsync" @onsubmit:preventDefault>
                <label>
                    Codigo
                    <input @bind="_positionForm.Code" required maxlength="40" />
                </label>
                <label>
                    Nombre
                    <input @bind="_positionForm.Name" required maxlength="180" />
                </label>
                <label>
                    Categoria
                    <input @bind="_positionForm.Category" required maxlength="80" />
                </label>
                <label>
                    Descripcion
                    <textarea @bind="_positionForm.Description" rows="3"></textarea>
                </label>
                <div class="form-actions">
                    <button class="action-button" type="submit" disabled="@_isSaving">
                        Guardar cargo
                    </button>
                </div>
            </form>
        </article>

        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Entidad</p>
                    <h2>Plantilla</h2>
                </div>
            </div>

            <form class="form-grid single" @onsubmit="SaveTemplateAsync" @onsubmit:preventDefault>
                <label>
                    Entidad
                    <select @bind="_templateForm.EntityId" required>
                        <option value="@Guid.Empty">Selecciona entidad</option>
                        @foreach (var entity in _entities)
                        {
                            <option value="@entity.Id">@entity.Name</option>
                        }
                    </select>
                </label>
                <label>
                    Nivel educacional
                    <select @bind="_templateForm.EducationLevelId" required>
                        @foreach (var item in _catalogs.EducationLevels)
                        {
                            <option value="@item.Id">@CatalogOptionLabel(item)</option>
                        }
                    </select>
                </label>
                <label>
                    Fecha efectiva
                    <input type="date" @bind="_templateForm.EffectiveDate" required />
                </label>
                <label>
                    Aprobado por
                    <input @bind="_templateForm.ApprovedBy" required maxlength="160" />
                </label>
                <div class="form-actions">
                    <button class="action-button" type="submit" disabled="@_isSaving">
                        Crear plantilla
                    </button>
                </div>
            </form>
        </article>

        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Plazas</p>
                    <h2>Agregar cargo</h2>
                </div>
            </div>

            <form class="form-grid single" @onsubmit="SaveTemplatePositionAsync" @onsubmit:preventDefault>
                <label>
                    Plantilla
                    <select @bind="_templatePositionForm.JobTemplateId" required>
                        <option value="@Guid.Empty">Selecciona plantilla</option>
                        @foreach (var template in _templates)
                        {
                            <option value="@template.Id">@TemplateLabel(template)</option>
                        }
                    </select>
                </label>
                <label>
                    Area
                    <select @bind="_templatePositionForm.AreaId" required>
                        <option value="@Guid.Empty">Selecciona area</option>
                        @foreach (var area in _areas)
                        {
                            <option value="@area.Id">@AreaLabel(area)</option>
                        }
                    </select>
                </label>
                <label>
                    Cargo
                    <select @bind="_templatePositionForm.PositionId" required>
                        <option value="@Guid.Empty">Selecciona cargo</option>
                        @foreach (var position in _positions)
                        {
                            <option value="@position.Id">@position.Name</option>
                        }
                    </select>
                </label>
                <label>
                    Plazas totales
                    <input type="number" min="1" @bind="_templatePositionForm.TotalVacancies" />
                </label>
                <label>
                    Plazas ocupadas
                    <input type="number" min="0" @bind="_templatePositionForm.FilledVacancies" />
                </label>
                <label>
                    Salario base
                    <input type="number" min="0" step="0.01" @bind="_templatePositionForm.BaseSalary" />
                </label>
                <label>
                    Categoria salarial
                    <input @bind="_templatePositionForm.SalaryCategory" required maxlength="80" />
                </label>
                <div class="form-actions">
                    <button class="action-button" type="submit" disabled="@_isSaving">
                        Agregar plaza
                    </button>
                </div>
            </form>
        </article>
    </section>

    <section class="work-grid">
        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Alta laboral</p>
                    <h2>Contratar candidato</h2>
                </div>
            </div>

            <form class="form-grid" @onsubmit="HireAsync" @onsubmit:preventDefault>
                <label>
                    Candidato
                    <select @bind="_hireForm.PersonId" required>
                        <option value="@Guid.Empty">Selecciona candidato</option>
                        @foreach (var person in _people)
                        {
                            <option value="@person.Id">@person.FullName</option>
                        }
                    </select>
                </label>
                <label>
                    Entidad
                    <select @bind="_hireForm.EntityId" required>
                        <option value="@Guid.Empty">Selecciona entidad</option>
                        @foreach (var entity in _entities)
                        {
                            <option value="@entity.Id">@entity.Name</option>
                        }
                    </select>
                </label>
                <label>
                    Cargo
                    <select @bind="_hireForm.PositionId" required>
                        <option value="@Guid.Empty">Selecciona cargo</option>
                        @foreach (var position in _positions)
                        {
                            <option value="@position.Id">@position.Name</option>
                        }
                    </select>
                </label>
                <label>
                    Fecha inicio
                    <input type="date" @bind="_hireForm.StartDate" required />
                </label>
                <label class="span-2">
                    Notas
                    <textarea @bind="_hireForm.Notes" rows="3"></textarea>
                </label>
                <div class="form-actions span-2">
                    <button class="action-button" type="submit" disabled="@_isSaving">
                        Contratar
                    </button>
                </div>
            </form>
        </article>

        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Disponibilidad</p>
                    <h2>Plazas activas</h2>
                </div>
            </div>

            <div class="compact-list">
                @if (_templatePositions.Count == 0)
                {
                    <p class="empty-state">No hay plazas registradas.</p>
                }
                @foreach (var templateGroup in TemplatePositionGroups())
                {
                    <div class="template-group">
                        <div class="template-group-heading">
                            <strong>@TemplateEntityLabel(templateGroup.Key)</strong>
                            <span>@TemplateEffectiveDateLabel(templateGroup.Key)</span>
                        </div>

                        @foreach (var areaGroup in AreaPositionGroups(templateGroup))
                        {
                            <div class="area-group">
                                <div class="area-group-heading">
                                    <span class="priority-chip">@AreaPriorityLabel(areaGroup.First())</span>
                                    <strong>@areaGroup.First().AreaName</strong>
                                </div>

                                @foreach (var templatePosition in areaGroup.OrderBy(position => position.PositionName))
                                {
                                    <div class="compact-row area-position-row">
                                        <div>
                                            <strong>@templatePosition.PositionName</strong>
                                            <span>@templatePosition.SalaryCategory</span>
                                        </div>
                                        <div class="right-stack">
                                            <span class="@GetAvailabilityClass(templatePosition)">
                                                @templatePosition.FilledVacancies / @templatePosition.TotalVacancies
                                            </span>
                                            <span>@templatePosition.BaseSalary.ToString("0.##")</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </article>
    </section>

    <section class="panel table-panel">
        <table>
            <thead>
                <tr>
                    <th>Candidato</th>
                    <th>Entidad</th>
                    <th>Cargo</th>
                    <th>Inicio</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employment in _employments)
                {
                    <tr>
                        <td><strong>@employment.PersonName</strong></td>
                        <td>@employment.EntityName</td>
                        <td>@employment.PositionName</td>
                        <td>@employment.StartDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="pill success">Activa</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private readonly PositionForm _positionForm = new();
    private readonly AreaForm _areaForm = new();
    private readonly TemplateForm _templateForm = new();
    private readonly TemplatePositionForm _templatePositionForm = new();
    private readonly HireForm _hireForm = new();
    private HumanResourcesCatalogsResponse _catalogs = EmptyCatalogs();
    private IReadOnlyList<OrganizationEntityResponse> _entities = [];
    private IReadOnlyList<PersonResponse> _people = [];
    private IReadOnlyList<StaffingAreaResponse> _areas = [];
    private IReadOnlyList<StaffingPositionResponse> _positions = [];
    private IReadOnlyList<JobTemplateResponse> _templates = [];
    private IReadOnlyList<JobTemplatePositionResponse> _templatePositions = [];
    private IReadOnlyList<EmploymentResponse> _employments = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _message;
    private string _messageCss = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;

        try
        {
            _catalogs = await HrClient.GetCatalogsAsync();
            _entities = await HrClient.GetOrganizationEntitiesAsync();
            _people = await HrClient.GetPeopleAsync();
            _areas = await HrClient.GetStaffingAreasAsync();
            _positions = await HrClient.GetStaffingPositionsAsync();
            _templates = await HrClient.GetJobTemplatesAsync();
            _templatePositions = await HrClient.GetJobTemplatePositionsAsync();
            _employments = await HrClient.GetEmploymentsAsync();
            ApplyDefaults();
        }
        catch (Exception exception)
        {
            ShowError(exception.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAreaAsync()
    {
        await SaveAsync(async () =>
        {
            _ = await HrClient.CreateStaffingAreaAsync(new CreateStaffingAreaRequest(
                _areaForm.Name,
                _areaForm.Priority));

            _areaForm.Reset();
            _areas = await HrClient.GetStaffingAreasAsync();
            ApplyDefaults();
            ShowSuccess("Area registrada correctamente.");
        });
    }

    private async Task SavePositionAsync()
    {
        await SaveAsync(async () =>
        {
            _ = await HrClient.CreateStaffingPositionAsync(new CreateStaffingPositionRequest(
                _positionForm.Code,
                _positionForm.Name,
                EmptyToNull(_positionForm.Description),
                _positionForm.Category));

            _positionForm.Reset();
            _positions = await HrClient.GetStaffingPositionsAsync();
            ShowSuccess("Cargo registrado correctamente.");
        });
    }

    private async Task SaveTemplateAsync()
    {
        await SaveAsync(async () =>
        {
            _ = await HrClient.CreateJobTemplateAsync(new CreateJobTemplateRequest(
                _templateForm.EntityId,
                _templateForm.EducationLevelId,
                DateOnly.FromDateTime(_templateForm.EffectiveDate),
                _templateForm.ApprovedBy));

            _templates = await HrClient.GetJobTemplatesAsync();
            ApplyDefaults();
            ShowSuccess("Plantilla creada correctamente.");
        });
    }

    private async Task SaveTemplatePositionAsync()
    {
        await SaveAsync(async () =>
        {
            _ = await HrClient.AddJobTemplatePositionAsync(
                _templatePositionForm.JobTemplateId,
                new AddJobTemplatePositionRequest(
                    _templatePositionForm.AreaId,
                    _templatePositionForm.PositionId,
                    _templatePositionForm.TotalVacancies,
                    _templatePositionForm.FilledVacancies,
                    _templatePositionForm.BaseSalary,
                    _templatePositionForm.SalaryCategory));

            _templatePositionForm.ResetVacancy();
            _templatePositions = await HrClient.GetJobTemplatePositionsAsync();
            ShowSuccess("Plaza agregada a la plantilla.");
        });
    }

    private async Task HireAsync()
    {
        await SaveAsync(async () =>
        {
            _ = await HrClient.HirePersonAsync(new HirePersonRequest(
                _hireForm.PersonId,
                _hireForm.EntityId,
                _hireForm.PositionId,
                DateOnly.FromDateTime(_hireForm.StartDate),
                EmptyToNull(_hireForm.Notes)));

            _templatePositions = await HrClient.GetJobTemplatePositionsAsync();
            _employments = await HrClient.GetEmploymentsAsync();
            ShowSuccess("Contratacion registrada correctamente.");
        });
    }

    private async Task SaveAsync(Func<Task> operation)
    {
        _isSaving = true;
        _message = null;

        try
        {
            await operation();
        }
        catch (Exception exception)
        {
            ShowError(exception.Message);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ApplyDefaults()
    {
        _templateForm.EntityId = FirstId(_entities, _templateForm.EntityId);
        _templateForm.EducationLevelId = FirstId(_catalogs.EducationLevels, _templateForm.EducationLevelId);
        _templatePositionForm.JobTemplateId = FirstId(_templates, _templatePositionForm.JobTemplateId);
        _templatePositionForm.AreaId = FirstId(_areas, _templatePositionForm.AreaId);
        _templatePositionForm.PositionId = FirstId(_positions, _templatePositionForm.PositionId);
        _hireForm.PersonId = FirstId(_people, _hireForm.PersonId);
        _hireForm.EntityId = FirstId(_entities, _hireForm.EntityId);
        _hireForm.PositionId = FirstId(_positions, _hireForm.PositionId);
    }

    private string TemplateLabel(JobTemplateResponse template)
    {
        return $"{EntityName(template.EntityId)} · {template.EffectiveDate:yyyy-MM-dd}";
    }

    private string TemplateEntityLabel(Guid jobTemplateId)
    {
        var template = _templates.FirstOrDefault(item => item.Id == jobTemplateId);
        return template is null ? "Plantilla no encontrada" : EntityName(template.EntityId);
    }

    private string TemplateEffectiveDateLabel(Guid jobTemplateId)
    {
        var template = _templates.FirstOrDefault(item => item.Id == jobTemplateId);
        return template is null ? string.Empty : template.EffectiveDate.ToString("yyyy-MM-dd");
    }

    private static string AreaLabel(StaffingAreaResponse area)
    {
        return $"{area.Priority:00} · {area.Name}";
    }

    private static string AreaPriorityLabel(JobTemplatePositionResponse templatePosition)
    {
        return templatePosition.AreaPriority == int.MaxValue ? "--" : templatePosition.AreaPriority.ToString("00");
    }

    private IEnumerable<IGrouping<Guid, JobTemplatePositionResponse>> TemplatePositionGroups()
    {
        return _templatePositions
            .GroupBy(position => position.JobTemplateId)
            .OrderBy(group => TemplateEntityLabel(group.Key));
    }

    private static IEnumerable<IGrouping<Guid, JobTemplatePositionResponse>> AreaPositionGroups(
        IEnumerable<JobTemplatePositionResponse> templatePositions)
    {
        return templatePositions
            .GroupBy(position => position.AreaId)
            .OrderBy(group => group.First().AreaPriority)
            .ThenBy(group => group.First().AreaName);
    }

    private string EntityName(Guid entityId)
    {
        return _entities.FirstOrDefault(entity => entity.Id == entityId)?.Name ?? "Entidad no encontrada";
    }

    private static string GetAvailabilityClass(JobTemplatePositionResponse templatePosition)
    {
        return templatePosition.HasAvailability ? "pill success" : "pill muted";
    }

    private void ShowSuccess(string message)
    {
        _message = message;
        _messageCss = "alert-success";
    }

    private void ShowError(string message)
    {
        _message = message;
        _messageCss = "alert-error";
    }

    private static Guid FirstId(IReadOnlyList<OrganizationEntityResponse> items, Guid current)
    {
        return current == Guid.Empty ? items.FirstOrDefault()?.Id ?? Guid.Empty : current;
    }

    private static Guid FirstId(IReadOnlyList<CatalogItemResponse> items, Guid current)
    {
        return current == Guid.Empty ? items.FirstOrDefault()?.Id ?? Guid.Empty : current;
    }

    private static string CatalogOptionLabel(CatalogItemResponse item)
    {
        return string.IsNullOrWhiteSpace(item.Code) ? item.Description : item.Code;
    }

    private static Guid FirstId(IReadOnlyList<PersonResponse> items, Guid current)
    {
        return current == Guid.Empty ? items.FirstOrDefault()?.Id ?? Guid.Empty : current;
    }

    private static Guid FirstId(IReadOnlyList<StaffingAreaResponse> items, Guid current)
    {
        return current == Guid.Empty ? items.FirstOrDefault()?.Id ?? Guid.Empty : current;
    }

    private static Guid FirstId(IReadOnlyList<StaffingPositionResponse> items, Guid current)
    {
        return current == Guid.Empty ? items.FirstOrDefault()?.Id ?? Guid.Empty : current;
    }

    private static Guid FirstId(IReadOnlyList<JobTemplateResponse> items, Guid current)
    {
        return current == Guid.Empty ? items.FirstOrDefault()?.Id ?? Guid.Empty : current;
    }

    private static string? EmptyToNull(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static HumanResourcesCatalogsResponse EmptyCatalogs()
    {
        return new HumanResourcesCatalogsResponse([], [], [], [], [], [], [], []);
    }

    private sealed class PositionForm
    {
        public string Code { get; set; } = string.Empty;

        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        public string Category { get; set; } = string.Empty;

        public void Reset()
        {
            Code = string.Empty;
            Name = string.Empty;
            Description = null;
            Category = string.Empty;
        }
    }

    private sealed class AreaForm
    {
        public string Name { get; set; } = string.Empty;

        public int Priority { get; set; } = 10;

        public void Reset()
        {
            Name = string.Empty;
            Priority = 10;
        }
    }

    private sealed class TemplateForm
    {
        public Guid EntityId { get; set; }

        public Guid EducationLevelId { get; set; }

        public DateTime EffectiveDate { get; set; } = DateTime.Today;

        public string ApprovedBy { get; set; } = "Direccion General";
    }

    private sealed class TemplatePositionForm
    {
        public Guid JobTemplateId { get; set; }

        public Guid AreaId { get; set; }

        public Guid PositionId { get; set; }

        public int TotalVacancies { get; set; } = 1;

        public int FilledVacancies { get; set; }

        public decimal BaseSalary { get; set; }

        public string SalaryCategory { get; set; } = string.Empty;

        public void ResetVacancy()
        {
            TotalVacancies = 1;
            FilledVacancies = 0;
            BaseSalary = 0;
            SalaryCategory = string.Empty;
        }
    }

    private sealed class HireForm
    {
        public Guid PersonId { get; set; }

        public Guid EntityId { get; set; }

        public Guid PositionId { get; set; }

        public DateTime StartDate { get; set; } = DateTime.Today;

        public string? Notes { get; set; }
    }
}
